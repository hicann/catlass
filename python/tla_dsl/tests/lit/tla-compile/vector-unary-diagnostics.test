// RUN: sed -n '/^\/\/ BEGIN_EXP_I32$/,/^\/\/ END_EXP_I32$/p' %s | sed '1d;$d;s|^// ||' > %t.exp_i32.mlir && not %tla_compile %t.exp_i32.mlir -o %t 2>&1 | %filecheck %s --check-prefix=EXP_I32
