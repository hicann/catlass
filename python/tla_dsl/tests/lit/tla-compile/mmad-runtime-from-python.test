// Every input in this test is emitted by a legal Python @tla.kernel. Do not add
// hand-written IR that bypasses frontend validation.
// RUN: %python %S/Inputs/generate_mmad_ir.py f16 | %tla_compile - -o - | %filecheck %s --check-prefix=F16
// RUN: %python %S/Inputs/generate_mmad_ir.py bf16 | %tla_compile - -o - | %filecheck %s --check-prefix=BF16
// RUN: %python %S/Inputs/generate_mmad_ir.py f32 | %tla_compile - -o - | %filecheck %s --check-prefix=F32
// RUN: %python %S/Inputs/generate_mmad_ir.py dynamic-init | %tla_compile - -o - | %filecheck %s --check-prefix=DYN-INIT
// RUN: %python %S/Inputs/generate_mmad_ir.py dynamic-unit | %tla_compile - -o - | %filecheck %s --check-prefix=DYN-UNIT
// RUN: %python %S/Inputs/generate_mmad_ir.py dynamic-both | %tla_compile - -o - | %filecheck %s --check-prefix=DYN-BOTH

// F16-COUNT-1: func.func private @mmad_half_half_float(
// F16-SAME: hacc.always_inline
// F16-SAME: hivm.func_core_type = #hivm.func_core_type<AIC>
// F16-SAME: llvm.emit_c_interface
// F16-LABEL: func.func @_static_f16_mmad_kernel(
// F16-DAG: [[INIT:%.*]] = llvm.mlir.constant(true) : i1
// F16-DAG: [[UNIT:%.*]] = llvm.mlir.constant(3 : i8) : i8
// F16-DAG: [[M:%.*]] = llvm.mlir.constant(128 : i64) : i64
// F16-DAG: [[K:%.*]] = llvm.mlir.constant(64 : i64) : i64
// F16: call @mmad_half_half_float({{%.*}}, {{%.*}}, {{%.*}}, [[M]], [[M]], [[K]], [[INIT]], [[UNIT]])
// F16-NOT: tla.mmad

// BF16-COUNT-1: func.func private @mmad_bf16_bf16_float(
// BF16-LABEL: func.func @_static_bf16_mmad_kernel(
// BF16-DAG: [[INIT:%.*]] = llvm.mlir.constant(true) : i1
// BF16-DAG: [[UNIT:%.*]] = llvm.mlir.constant(3 : i8) : i8
// BF16-DAG: [[M:%.*]] = llvm.mlir.constant(128 : i64) : i64
// BF16-DAG: [[K:%.*]] = llvm.mlir.constant(64 : i64) : i64
// BF16: call @mmad_bf16_bf16_float({{%.*}}, {{%.*}}, {{%.*}}, [[M]], [[M]], [[K]], [[INIT]], [[UNIT]])
// BF16-NOT: tla.mmad

// F32-COUNT-1: func.func private @mmad_float_float_float(
// F32-LABEL: func.func @_static_f32_mmad_kernel(
// F32-DAG: [[INIT:%.*]] = llvm.mlir.constant(true) : i1
// F32-DAG: [[UNIT:%.*]] = llvm.mlir.constant(3 : i8) : i8
// F32-DAG: [[MN:%.*]] = llvm.mlir.constant(32 : i64) : i64
// F32-COUNT-1: hivm.hir.set_ctrl false at ctrl[60]
// F32-COUNT-1: hivm.hir.set_ctrl true at ctrl[48]
// F32: call @mmad_float_float_float({{%.*}}, {{%.*}}, {{%.*}}, [[MN]], [[MN]], [[MN]], [[INIT]], [[UNIT]])
// F32-NOT: tla.mmad

// DYN-INIT-COUNT-1: func.func private @mmad_float_float_float(
// DYN-INIT-LABEL: func.func @_dynamic_init_mmad_kernel(
// DYN-INIT: call @mmad_float_float_float({{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}})
// DYN-INIT-NOT: tla.mmad

// DYN-UNIT-COUNT-1: func.func private @mmad_float_float_float(
// DYN-UNIT-LABEL: func.func @_dynamic_unit_mmad_kernel(
// DYN-UNIT: call @mmad_float_float_float({{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}})
// DYN-UNIT-NOT: tla.mmad

// DYN-BOTH-COUNT-1: func.func private @mmad_float_float_float(
// DYN-BOTH-LABEL: func.func @_dynamic_init_unit_mmad_kernel(
// DYN-BOTH: call @mmad_float_float_float({{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}}, {{%.*}})
// DYN-BOTH-NOT: tla.mmad
