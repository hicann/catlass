// RUN: sed -n '/^\/\/ BEGIN_EXP_OUTSIDE$/,/^\/\/ END_EXP_OUTSIDE$/p' %s | sed '1d;$d;s|^// ||' > %t.exp_outside.mlir && not %tla_compile %t.exp_outside.mlir -o %t 2>&1 | %filecheck %s --check-prefix=EXP_OUTSIDE
// RUN: sed -n '/^\/\/ BEGIN_REDUCE_OUTSIDE$/,/^\/\/ END_REDUCE_OUTSIDE$/p' %s | sed '1d;$d;s|^// ||' > %t.reduce_outside.mlir && not %tla_compile %t.reduce_outside.mlir -o %t 2>&1 | %filecheck %s --check-prefix=REDUCE_OUTSIDE
// RUN: sed -n '/^\/\/ BEGIN_ARANGE_OUTSIDE$/,/^\/\/ END_ARANGE_OUTSIDE$/p' %s | sed '1d;$d;s|^// ||' > %t.arange_outside.mlir && not %tla_compile %t.arange_outside.mlir -o %t 2>&1 | %filecheck %s --check-prefix=ARANGE_OUTSIDE

// EXP_OUTSIDE: error:
// EXP_OUTSIDE-SAME: 'tla.exp' op must be nested inside a tla.vec.func region
// REDUCE_OUTSIDE: error:
// REDUCE_OUTSIDE-SAME: 'tla.reduce' op must be nested inside a tla.vec.func region
// ARANGE_OUTSIDE: error:
// ARANGE_OUTSIDE-SAME: 'tla.arange' op must be nested inside a tla.vec.func region

