__KERNEL_INCLUDES__

using namespace Catlass;

__KERNEL_TYPE_DEFINITIONS__

extern "C" __global__ __aicore__ void __KERNEL_NAME___impl(__KERNEL_IMPL_PARAMS__)
{
    __KERNEL_IMPL_BODY__
}

namespace catlass_kernel {

void __KERNEL_NAME__(uint32_t coreNum, void* stream, __KERNEL_LAUNCH_PARAMS__)
{
    __KERNEL_NAME___impl<<<coreNum, nullptr, stream>>>(__KERNEL_LAUNCH_ARGS__);
}
} // namespace catlass_kernel
