// === Append to kernel/catlass_kernel.asc ===

#include "catlass/arch/arch.hpp"
#include "catlass/catlass.hpp"
#include "catlass/gemm/block/block_mmad.hpp"
#include "catlass/gemm/block/block_swizzle.hpp"
#include "catlass/gemm/dispatch_policy.hpp"
#include "catlass/gemm/gemm_type.hpp"
#include "catlass/gemm/kernel/grouped_matmul_slice_m.hpp"
#include "catlass/layout/layout.hpp"
#include "catlass/status.hpp"

using ElementGroupList_gmm = int64_t;

using ArchTag_gmm = Arch::AtlasA2;

constexpr uint32_t preloadStages_gmm_kgt = 1;
constexpr uint32_t l1Stages_gmm_kgt = 2;
constexpr uint32_t l0AStages_gmm_kgt = 2;
constexpr uint32_t l0BStages_gmm_kgt = 4;
constexpr uint32_t l0CStages_gmm_kgt = 1;

using DispatchPolicy_gmm_kgt = Gemm::MmadAtlasA2PreloadAsync<
    preloadStages_gmm_kgt, l1Stages_gmm_kgt, l0AStages_gmm_kgt, l0BStages_gmm_kgt, l0CStages_gmm_kgt, true, true>;
using L1TileShape_gmm_kgt = GemmShape<256, 128, 256>;
using L0TileShape_gmm_kgt = GemmShape<256, 128, 64>;

using AType_gmm_kgt = Gemm::GemmType<half, layout::RowMajor>;
using BType_gmm_kgt = Gemm::GemmType<half, layout::RowMajor>;
using CType_gmm_kgt = Gemm::GemmType<half, layout::RowMajor>;

using BlockMmad_gmm_kgt = Gemm::Block::BlockMmad<
    DispatchPolicy_gmm_kgt, L1TileShape_gmm_kgt, L0TileShape_gmm_kgt, AType_gmm_kgt, BType_gmm_kgt, CType_gmm_kgt>;
using BlockEpilogue_gmm_kgt = void;
using BlockScheduler_gmm_kgt = Gemm::Block::GemmIdentityBlockSwizzle<3, 1>;

using MatmulKernel_gmm_kgt = Gemm::Kernel::GroupedMatmulSliceM<
    BlockMmad_gmm_kgt, BlockEpilogue_gmm_kgt, BlockScheduler_gmm_kgt, ElementGroupList_gmm>;

constexpr uint32_t preloadStages_gmm_kle = 1;
constexpr uint32_t l1Stages_gmm_kle = 2;
constexpr uint32_t l0AStages_gmm_kle = 4;
constexpr uint32_t l0BStages_gmm_kle = 2;
constexpr uint32_t l0CStages_gmm_kle = 1;

using DispatchPolicy_gmm_kle = Gemm::MmadAtlasA2PreloadAsync<
    preloadStages_gmm_kle, l1Stages_gmm_kle, l0AStages_gmm_kle, l0BStages_gmm_kle, l0CStages_gmm_kle, true, true>;
using L1TileShape_gmm_kle = GemmShape<128, 256, 256>;
using L0TileShape_gmm_kle = GemmShape<128, 256, 64>;

using AType_gmm_kle = Gemm::GemmType<half, layout::RowMajor>;
using BType_gmm_kle = Gemm::GemmType<half, layout::RowMajor>;
using CType_gmm_kle = Gemm::GemmType<half, layout::RowMajor>;

using BlockMmad_gmm_kle = Gemm::Block::BlockMmad<
    DispatchPolicy_gmm_kle, L1TileShape_gmm_kle, L0TileShape_gmm_kle, AType_gmm_kle, BType_gmm_kle, CType_gmm_kle>;
using BlockEpilogue_gmm_kle = void;
using BlockScheduler_gmm_kle = Gemm::Block::GemmIdentityBlockSwizzle<3, 0>;

using MatmulKernel_gmm_kle = Gemm::Kernel::GroupedMatmulSliceM<
    BlockMmad_gmm_kle, BlockEpilogue_gmm_kle, BlockScheduler_gmm_kle, ElementGroupList_gmm>;

extern "C" __global__ __aicore__ void grouped_matmul_impl_kgt(MatmulKernel_gmm_kgt::Params params)
{
    MatmulKernel_gmm_kgt op;
    op(params);
}

extern "C" __global__ __aicore__ void grouped_matmul_impl_kle(MatmulKernel_gmm_kle::Params params)
{
    MatmulKernel_gmm_kle op;
    op(params);
}

namespace catlass_kernel {

void grouped_matmul(
    uint32_t coreNum, void* stream, void* a, void* b, void* c, void* groupList, uint32_t problemCount, uint32_t M,
    uint32_t N, uint32_t K)
{
    GemmCoord problemShape(M, N, K);
    uint8_t* deviceA = reinterpret_cast<uint8_t*>(a);
    uint8_t* deviceB = reinterpret_cast<uint8_t*>(b);
    uint8_t* deviceC = reinterpret_cast<uint8_t*>(c);
    uint8_t* deviceGroupList = reinterpret_cast<uint8_t*>(groupList);

    if (K > N) {
        MatmulKernel_gmm_kgt::Arguments arguments{problemShape, problemCount, deviceGroupList,
                                                  deviceA,      deviceB,      deviceC};
        MatmulKernel_gmm_kgt::Params params = MatmulKernel_gmm_kgt::ToUnderlyingArguments(arguments, nullptr);
        grouped_matmul_impl_kgt<<<coreNum, nullptr, stream>>>(params);
    } else {
        MatmulKernel_gmm_kle::Arguments arguments{problemShape, problemCount, deviceGroupList,
                                                  deviceA,      deviceB,      deviceC};
        MatmulKernel_gmm_kle::Params params = MatmulKernel_gmm_kle::ToUnderlyingArguments(arguments, nullptr);
        grouped_matmul_impl_kle<<<coreNum, nullptr, stream>>>(params);
    }
}

} // namespace catlass_kernel
